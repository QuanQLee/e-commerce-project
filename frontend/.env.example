# Gateway base URL exposed to the browser. Replace with your HTTPS endpoint in production.
VITE_API_BASE_URL=http://localhost:8000
# Optional API key header used for authenticated calls.
VITE_API_KEY=mytestkey123
# Toggle strict runtime validation in CI/CD.
VITE_RUNTIME_ENV_STRICT=false
# Enable the SSO button on the login screen when your IdP is wired up.
VITE_SSO_ENABLED=0

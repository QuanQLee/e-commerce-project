# Gateway base URL exposed to the browser. In production set this to your public HTTPS endpoint.
VITE_API_BASE_URL=http://localhost:8000
# Optional API key header passed with every request.
VITE_API_KEY=__OPTIONAL_API_KEY__
# Toggle runtime env validation (set to true in CI/CD once variables are wired).
VITE_RUNTIME_ENV_STRICT=false
# Enable SSO login button (expects /auth/oidc/login on the API gateway).
VITE_SSO_ENABLED=1
# Development-only merchant password form. Keep this false for production SSO-only deployments.
VITE_PASSWORD_LOGIN_ENABLED=1
# Development-only self-registration toggle. Keep this false unless you have a verified onboarding flow.
VITE_SELF_REGISTRATION_ENABLED=1

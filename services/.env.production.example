### Production baseline example (EC2 + RDS + ElastiCache + ALB)
# Copy to a secure location and load via deploy-ec2.ps1 -EnvFile or Secrets Manager.

# Registry
REGISTRY=123456789012.dkr.ecr.us-west-1.amazonaws.com/ecommerce
TAG=v1.0.0

# App environment
ASPNETCORE_ENVIRONMENT=Production

# Public endpoints
PUBLIC_BASE_URL=https://shop.example.com
AUTH_PUBLIC_BASE=https://auth.example.com
AUTH_INTERNAL_BASE=http://auth.api

# Kong gateway
KONG_CORS_ORIGIN_PRIMARY=https://shop.example.com
KONG_CORS_ORIGIN_SECONDARY=https://merchant.example.com
KONG_RATE_LIMIT_MINUTE=120
KONG_REQUEST_BODY_LIMIT_MB=2
KONG_FRONTEND_JWT_SECRET=__GENERATE_UNIQUE_SECRET__
KONG_ADMIN_JWT_SECRET=__GENERATE_UNIQUE_SECRET__

# Auth service secrets (required in production)
AUTH_BFF_REDIRECT_URI=https://shop.example.com/auth/callback
AUTH_ALLOWED_CORS_ORIGIN_0=https://shop.example.com
AUTH_ALLOWED_CORS_ORIGIN_1=https://merchant.example.com
AUTH_SAMPLE_CLIENT_SECRET=__GENERATE_UNIQUE_SECRET__
AUTH_ADMIN_CLIENT_SECRET=__GENERATE_UNIQUE_SECRET__
AUTH_SECONDARY_ADMIN_CLIENT_SECRET=__GENERATE_UNIQUE_SECRET__
AUTH_DEFAULT_TEST_USER_PASSWORD=__SET_STRONG_PASSWORD__

# BFF
BFF_CLIENT_ID=frontend-client
BFF_CLIENT_SECRET=__GENERATE_UNIQUE_SECRET__
BFF_SCOPE=api1 offline_access
BFF_ALLOW_PASSWORD_GRANT=false
BFF_ALLOWED_ORIGINS=https://shop.example.com,https://merchant.example.com
BFF_COOKIE_SECURE=true
BFF_COOKIE_SAMESITE=lax
BFF_SESSION_TTL=14400
BFF_SESSION_NAMESPACE=bff-session

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com/v1/traces
OTEL_SERVICE_NAME=bff

# RDS (per-service credentials)
CATALOG_DB_NAME=catalog
CATALOG_DB_USER=catalog_svc
CATALOG_DB_PASSWORD=__GENERATE_UNIQUE_SECRET__
ORDER_DB_NAME=order
ORDER_DB_USER=order_svc
ORDER_DB_PASSWORD=__GENERATE_UNIQUE_SECRET__
USER_DB_NAME=user
USER_DB_USER=user_svc
USER_DB_PASSWORD=__GENERATE_UNIQUE_SECRET__
SHIPPING_DB_NAME=shipping
SHIPPING_DB_USER=shipping_svc
SHIPPING_DB_PASSWORD=__GENERATE_UNIQUE_SECRET__
PAYMENT_DB_NAME=payment
PAYMENT_DB_USER=payment_svc
PAYMENT_DB_PASSWORD=__GENERATE_UNIQUE_SECRET__
INVENTORY_DB_NAME=inventory
INVENTORY_DB_USER=inventory_svc
INVENTORY_DB_PASSWORD=__GENERATE_UNIQUE_SECRET__
ANALYTICS_DB_NAME=analytics
ANALYTICS_DB_USER=analytics_svc
ANALYTICS_DB_PASSWORD=__GENERATE_UNIQUE_SECRET__
AUTH_DB_NAME=auth
AUTH_DB_USER=auth_svc
AUTH_DB_PASSWORD=__GENERATE_UNIQUE_SECRET__

# Redis (ElastiCache)
CART_REDIS_URL=rediss://:__REDIS_PASSWORD__@cache.example.amazonaws.com:6379
BFF_SESSION_REDIS_URL=rediss://:__REDIS_PASSWORD__@cache.example.amazonaws.com:6379/0

# DB provisioning (optional if you run scripts/provision-db-roles.sh)
PGHOST=database.example.amazonaws.com
PGPORT=5432
PGUSER=master_user
PGPASSWORD=__MASTER_PASSWORD__

# CloudWatch logs
AWS_REGION=us-west-2
AWS_LOG_GROUP=/ecs/ecommerce-prod
AWS_LOG_STREAM_PREFIX=ecommerce

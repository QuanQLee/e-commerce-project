# Example environment values for docker-compose based deployments.
DB_USER=catalog_admin
DB_PASSWORD=changeme
DB_NAME=catalog
REGISTRY=

# Kong gateway overrides
KONG_CORS_ORIGIN_PRIMARY=https://storefront.example.com
KONG_CORS_ORIGIN_SECONDARY=https://merchant.example.com
KONG_RATE_LIMIT_MINUTE=60
KONG_REQUEST_BODY_LIMIT_MB=2
KONG_FRONTEND_JWT_SECRET=please-change-frontend-secret
KONG_ADMIN_JWT_SECRET=please-change-admin-secret

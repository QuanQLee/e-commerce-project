# Example environment values for docker-compose based deployments.
DB_USER=catalog_admin
DB_PASSWORD=__CHANGE_ME__
DB_NAME=catalog
REGISTRY=

# Kong gateway overrides
KONG_CORS_ORIGIN_PRIMARY=https://storefront.example.com
KONG_CORS_ORIGIN_SECONDARY=https://merchant.example.com
KONG_RATE_LIMIT_MINUTE=60
KONG_REQUEST_BODY_LIMIT_MB=2
KONG_FRONTEND_JWT_SECRET=__GENERATE_UNIQUE_SECRET__
KONG_ADMIN_JWT_SECRET=__GENERATE_UNIQUE_SECRET__

# Service-specific database credentials (override per environment)
CATALOG_DB_NAME=catalog
CATALOG_DB_USER=catalog_svc
CATALOG_DB_PASSWORD=__CHANGE_ME__
ORDER_DB_NAME=order
ORDER_DB_USER=order_svc
ORDER_DB_PASSWORD=__CHANGE_ME__
USER_DB_NAME=user
USER_DB_USER=user_svc
USER_DB_PASSWORD=__CHANGE_ME__
SHIPPING_DB_NAME=shipping
SHIPPING_DB_USER=shipping_svc
SHIPPING_DB_PASSWORD=__CHANGE_ME__
PAYMENT_DB_NAME=payment
PAYMENT_DB_USER=payment_svc
PAYMENT_DB_PASSWORD=__CHANGE_ME__
INVENTORY_DB_NAME=inventory
INVENTORY_DB_USER=inventory_svc
INVENTORY_DB_PASSWORD=__CHANGE_ME__
ANALYTICS_DB_NAME=analytics
ANALYTICS_DB_USER=analytics_svc
ANALYTICS_DB_PASSWORD=__CHANGE_ME__
AUTH_DB_NAME=auth
AUTH_DB_USER=auth_svc
AUTH_DB_PASSWORD=__CHANGE_ME__

# Optional: database provisioning (requires psql and PGPASSWORD)
PGHOST=__DB_HOST__
PGPORT=5432
PGUSER=__DB_ADMIN_USER__
PGPASSWORD=__DB_ADMIN_PASSWORD__

# Optional: CloudWatch logs (docker-compose.aws.logging.yml)
AWS_REGION=us-west-2
AWS_LOG_GROUP=/ecs/ecommerce
AWS_LOG_STREAM_PREFIX=ecommerce

# Redis connection strings (use rediss:// with TLS for production)
CART_REDIS_URL=redis://cart.redis:6379
BFF_SESSION_REDIS_URL=redis://bff-redis:6379/0

# BFF configuration (required in production)
AUTH_INTERNAL_BASE=http://auth.api
AUTH_PUBLIC_BASE=http://localhost:7000
BFF_CLIENT_ID=__CLIENT_ID__
BFF_CLIENT_SECRET=__CLIENT_SECRET__
BFF_SCOPE=api1 offline_access
BFF_ALLOW_PASSWORD_GRANT=false
BFF_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:4000
BFF_COOKIE_SECURE=false
BFF_COOKIE_SAMESITE=lax
BFF_SESSION_TTL=14400
BFF_SESSION_NAMESPACE=bff-session

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=bff

# Auth service secrets (required in production)
AUTH_BFF_REDIRECT_URI=http://localhost:9080/auth/callback
AUTH_ALLOWED_CORS_ORIGIN_0=http://localhost:3000
AUTH_ALLOWED_CORS_ORIGIN_1=http://localhost:3002
AUTH_SAMPLE_CLIENT_SECRET=__GENERATE_UNIQUE_SECRET__
AUTH_ADMIN_CLIENT_SECRET=__GENERATE_UNIQUE_SECRET__
AUTH_SECONDARY_ADMIN_CLIENT_SECRET=__GENERATE_UNIQUE_SECRET__
AUTH_DEFAULT_TEST_USER_PASSWORD=__SET_STRONG_PASSWORD__

# Admin service CORS + audit logging
ADMIN_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:4000
ADMIN_AUDIT_LOG_ENABLED=true
